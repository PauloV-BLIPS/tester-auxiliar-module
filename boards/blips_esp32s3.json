{
    "name": "Neuron esp32-s3-optocoupler (4MB QIO, No PSRAM)",
    "vendor": "Blips Ativos",
    "url": "https://blips.com.br",
    "build": {
        "core": "esp32",
        "mcu": "esp32s3",
        "variant": "esp32s3",
        "f_cpu": "240000000L",
        "f_flash": "80000000L",
        "flash_mode": "qio",
        "arduino": {
            "partitions": "partitions/2_otas.csv"
        },
        "extra_flags": [
            "-DARDUINO_ESP32S3_DEV",
            "-DARDUINO_USB_MODE=0",
            "-DARDUINO_USB_CDC_ON_BOOT=0",
            "-DARDUINO_RUNNING_CORE=1",
            "-DARDUINO_EVENT_RUNNING_CORE=1",
            "-DBOARD_HAS_PSRAM=0"
        ],
        "hwids": [
            [
                "0x303A",
                "0x1001"
            ]
        ]
    },
    "upload": {
        "flash_size": "4MB",
        "maximum_size": 4194304,
        "maximum_ram_size": 327680,
        "speed": 460800,
        "require_upload_port": true
    },
    "debug": {
        "default_tool": "esp-builtin",
        "onboard_tools": [
            "esp-builtin"
        ],
        "openocd_target": "esp32s3.cfg"
    },
    "frameworks": [
        "arduino",
        "espidf"
    ],
    "connectivity": [
        "wifi",
        "bluetooth"
    ]
}